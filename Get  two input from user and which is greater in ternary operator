import java.util.Scanner;
class hello{
    public static void main(String args[]){
        Scanner scan = new Scanner(System.in);
        System.out.print("Enter the first integer:");
        int a = scan.nextInt();
        System.out.print("Enter the second integer:");
        int b = scan.nextInt();
        
        int greater = a>b?a:b;
        System.out.print(greater);

    }
}
